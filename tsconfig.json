{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@cesium/core": ["./packages/core/src/index.ts"],
      "@cesium/client": ["./packages/client/src/index.ts"],
      "@cesium/client/react": ["./packages/client/src/react.ts"],
      "@cesium/design": ["./packages/design/src/index.ts"],
      "@cesium/ui-web": ["./packages/ui-web/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "server/**/*",
    "test/**/*",
    "apps/mobile/**/*",
    "apps/desktop/**/*",
    "apps/desktop-renderer/**/*",
    "apps/web/**/*"
  ]
}
