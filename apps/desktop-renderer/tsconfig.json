{
  "extends": "../../packages/config/tsconfig/react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vite/client", "react", "react-dom"],
    "paths": {
      "@/*": ["../../src/*"],
      "next/dynamic": ["./src/next-shims/dynamic.tsx"],
      "next/link": ["./src/next-shims/link.tsx"],
      "next/navigation": ["./src/next-shims/navigation.tsx"],
      "@cesium/core": ["../../packages/core/src/index.ts"],
      "@cesium/api-client": ["../../packages/api-client/src/index.ts"],
      "@cesium/design": ["../../packages/design/src/index.ts"],
      "@cesium/ui-web": ["../../packages/ui-web/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../src/**/*.ts",
    "../../src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ]
}
