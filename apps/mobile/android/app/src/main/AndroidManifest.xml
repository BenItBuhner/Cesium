<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

  <application
    android:name=".MainApplication"
    android:allowBackup="false"
    android:label="Cesium"
    android:theme="@style/AppTheme"
    android:usesCleartextTraffic="true">
    <activity
      android:name=".MainActivity"
      android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
      android:exported="true"
      android:launchMode="singleTask"
      android:screenOrientation="fullUser"
      android:windowSoftInputMode="adjustResize">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data android:scheme="cesium" android:host="mobile" />
      </intent-filter>
    </activity>

    <service
      android:name=".background.CesiumForegroundService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="User-initiated AI agent run monitoring and intervention surfacing" />
    </service>

    <service
      android:name=".background.CesiumHeadlessService"
      android:exported="false" />

    <service
      android:name=".phonecontrol.CesiumMobileControlService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="User-enabled authenticated connection for remote AI assistant actions on this device" />
    </service>

    <service
      android:name=".phonecontrol.CesiumAccessibilityService"
      android:description="@string/mobile_control_accessibility_description"
      android:exported="true"
      android:label="@string/mobile_control_accessibility_label"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/mobile_control_accessibility_service" />
    </service>

    <service
      android:name=".assistant.CesiumVoiceInteractionService"
      android:exported="true"
      android:label="@string/assistant_service_label"
      android:permission="android.permission.BIND_VOICE_INTERACTION"
      android:process=":assistant">
      <intent-filter>
        <action android:name="android.service.voice.VoiceInteractionService" />
      </intent-filter>
      <meta-data
        android:name="android.voice_interaction"
        android:resource="@xml/voice_interaction_service" />
    </service>

    <service
      android:name=".assistant.CesiumVoiceInteractionSessionService"
      android:exported="true"
      android:permission="android.permission.BIND_VOICE_INTERACTION"
      android:process=":assistant" />

    <service
      android:name=".assistant.CesiumRecognitionService"
      android:exported="true"
      android:permission="android.permission.BIND_SPEECH_RECOGNITION_SERVICE"
      android:process=":assistant">
      <intent-filter>
        <action android:name="android.speech.RecognitionService" />
        <category android:name="android.intent.category.DEFAULT" />
      </intent-filter>
      <meta-data
        android:name="android.speech"
        android:resource="@xml/recognition_service" />
    </service>

    <service
      android:name=".wear.CesiumWearCompanionService"
      android:exported="true">
      <intent-filter>
        <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
        <data android:scheme="wear" android:host="*" />
      </intent-filter>
    </service>

    <receiver
      android:name=".notifications.CesiumNotificationActionReceiver"
      android:exported="false" />
  </application>
</manifest>
