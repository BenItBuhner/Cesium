{
  "name": "@cesium/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "react-native start",
    "android": "react-native run-android",
    "build": "npm run build:android:debug",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:android:debug": "npm run bundle:android && cd android && gradlew.bat assembleDebug",
    "build:android:release": "npm run bundle:android && cd android && gradlew.bat assembleRelease",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test ./src/**/*.test.ts",
    "e2e:detox:android": "detox test --configuration android.emu.debug",
    "e2e:maestro:android": "maestro test e2e/maestro"
  },
  "dependencies": {
    "@cesium/client": "file:../../packages/client",
    "@cesium/core": "file:../../packages/core",
    "@cesium/design": "file:../../packages/design",
    "@notifee/react-native": "latest",
    "@react-native-community/netinfo": "latest",
    "lucide-react-native": "^1.23.0",
    "nativewind": "5.0.0-preview.4",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-mmkv": "^3.3.3",
    "react-native-reanimated": "^4.5.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.10.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.2.0",
    "@react-native-community/cli-platform-android": "20.2.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "detox": "latest",
    "expo": "^57.0.2",
    "jest": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
