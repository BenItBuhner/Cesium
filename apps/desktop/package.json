{
  "name": "@cesium/desktop",
  "version": "0.1.0",
  "description": "Cesium Desktop",
  "author": "Cesium",
  "private": true,
  "type": "module",
  "main": "./src/electron-main.mjs",
  "scripts": {
    "dev": "node ./src/dev.mjs",
    "check": "node ./src/main.mjs --check && electron --version",
    "build": "npm run build -w @cesium/core && npm run build -w @cesium/desktop-renderer && npm run build -w cesium-server && npm run check",
    "smoke": "node ./src/main.mjs --smoke",
    "package": "npm run build && node ../../scripts/prepare-desktop-server-runtime.cjs && node ../../scripts/assert-desktop-package-safe.cjs && node ../../node_modules/electron-builder/cli.js --dir && node ../../scripts/edit-desktop-exe-metadata.cjs",
    "install:unpacked": "npm run package && node ../../scripts/install-desktop-unpacked.cjs",
    "package:win": "npm run build && node ../../scripts/prepare-desktop-server-runtime.cjs && node ../../scripts/assert-desktop-package-safe.cjs && node ../../node_modules/electron-builder/cli.js --win --publish never"
  },
  "dependencies": {
    "@cesium/core": "file:../../packages/core",
    "@cesium/design": "file:../../packages/design",
    "@cesium/ui-web": "file:../../packages/ui-web"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.cesium.desktop",
    "productName": "Cesium Desktop",
    "npmRebuild": false,
    "directories": {
      "output": "out"
    },
    "compression": "store",
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json"
    ],
    "icon": "build/icon.ico",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "../../server/dist",
        "to": "server/dist"
      },
      {
        "from": "../../server/package.json",
        "to": "server/package.json"
      },
      {
        "from": ".server-runtime/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*",
          "!cesium/**",
          "!**/cesium/**",
          "!**/g/caches/**",
          "!**/.gradle/**",
          "!**/android/**",
          "!**/.cache/**",
          "!**/node_modules/.cache/**",
          "!**/.local-browsers/**"
        ]
      },
      {
        "from": ".server-runtime/node.exe",
        "to": "server/node.exe"
      },
      {
        "from": "../desktop-renderer/dist",
        "to": "desktop-renderer"
      }
    ],
    "win": {
      "executableName": "Cesium",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "Cesium",
      "uninstallDisplayName": "Cesium",
      "license": "build/terms.txt"
    }
  }
}
