{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../src/*"],
      "@cesium/core": ["../../packages/core/src/index.ts"],
      "@cesium/client": ["../../packages/client/src/index.ts"],
      "@cesium/client/react": ["../../packages/client/src/react.ts"],
      "@cesium/design": ["../../packages/design/src/index.ts"],
      "@cesium/ui-web": ["../../packages/ui-web/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../src/**/*.ts",
    "../../src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
