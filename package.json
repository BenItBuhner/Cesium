{
  "name": "cesium",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "apps/desktop",
    "apps/desktop-renderer",
    "packages/api-client",
    "packages/config",
    "packages/core",
    "packages/design",
    "packages/server",
    "packages/ui-web",
    "server"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:web": "npm run dev --workspace @cesium/web",
    "dev:mobile": "npm run start --workspace @cesium/mobile",
    "android:mobile": "npm run android --workspace @cesium/mobile",
    "dev:desktop": "npm run dev --workspace @cesium/desktop",
    "dev:server": "npm run dev --prefix server",
    "build": "next build",
    "build:web": "npm run build --workspace @cesium/web",
    "build:mobile": "npm run build --workspace @cesium/mobile",
    "build:desktop": "npm run build --workspace @cesium/desktop",
    "build:all": "npm run build:packages && npm run build:web && npm run build:desktop && npm run build:mobile",
    "build:packages": "npm run build --workspace @cesium/core --workspace @cesium/api-client --workspace @cesium/design --workspace @cesium/ui-web --if-present",
    "start": "next start",
    "start:all": "bash -c 'npm run start & npm run start --prefix server & wait'",
    "prod": "npm run build && npm run build --prefix server && npm run start:all",
    "postinstall": "node scripts/patch-react-native-gradle-plugin-foojay.cjs",
    "lint": "eslint",
    "test": "tsx --test ./test/server-connections.test.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "webpack": "^5.105.4"
  }
}
