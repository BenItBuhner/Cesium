{
  "name": "cesium-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/runtime/bun-server.ts",
    "dev:node": "cross-env NODE_ENV=development NODE_OPTIONS=--max-old-space-size=3072 tsx watch src/index.ts",
    "dev:bun": "bun --watch src/runtime/bun-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun src/runtime/bun-server.ts",
    "start:node": "cross-env NODE_ENV=production node --max-old-space-size=3072 dist/index.js",
    "start:bun": "bun src/runtime/bun-server.ts",
    "test": "node --import tsx --test ./test/*.test.ts",
    "test:bun:smoke": "bun test ./test/bun-smoke.test.ts",
    "seed:fat-conversations": "bun ./scripts/seed-fat-conversations.ts",
    "seed:perf:small": "bun ./scripts/seed-fat-conversations.ts --conversations=3 --turns=25",
    "seed:perf:medium": "bun ./scripts/seed-fat-conversations.ts --conversations=12 --turns=250",
    "seed:perf:fat": "bun ./scripts/seed-fat-conversations.ts --conversations=30 --turns=3500",
    "perf:run": "tsx ./scripts/perf-runner.ts",
    "perf:browser": "tsx ./scripts/perf-browser.ts",
    "perf:bun": "bun ./scripts/perf-runner.ts",
    "perf:compare": "tsx ./scripts/perf-compare.ts",
    "sdk:probe": "tsx ./scripts/cursor-sdk-probe.ts",
    "codex:app-server-probe": "bun ./scripts/codex-app-server-probe.ts",
    "opencode:server-probe": "bun ./scripts/opencode-server-probe.ts",
    "bun:native-check": "bun ./scripts/bun-native-check.ts",
    "bun:live-smoke": "bun ./scripts/bun-live-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "storage:stats": "tsx ./scripts/storage-migrate.ts --stats",
    "storage:migrate": "tsx ./scripts/storage-migrate.ts"
  },
  "dependencies": {
    "@cesium/core": "file:../packages/core",
    "@cursor/sdk": "^1.0.11",
    "@hono/node-server": "^1.19.6",
    "cesium": "file:..",
    "chokidar": "^4.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.2",
    "ioredis": "^5.10.1",
    "node-pty": "^1.0.0",
    "playwright": "^1.56.0",
    "postgres": "^3.4.9",
    "ssh2": "^1.17.0",
    "undici": "^7.24.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
