# Copy to `server/.env` or set the same keys in the repo root `.env.local`.
# See repo root `.env.example` for full documentation.

WORKSPACE_ROOT=C:\Users\benpr\OneDrive\Documents\Projects\opencursor
# WORKSPACE_ALLOWED_ROOTS=C:\Users\benpr\OneDrive\Documents\Projects
PORT=9100
# When `PUBLIC_HOST` is an RFC1918 LAN IP (e.g. 192.168.x.x), credentialed CORS also
# allows other private-LAN `Origin` values (another workstation opening the Next UI).
# Set to `0` to disable and require an explicit match in root `ALLOWED_ORIGINS` only.
# OPENCURSOR_ALLOW_PRIVATE_LAN_ORIGINS=0
# OPENCURSOR_CURSOR_CLI_BIN=/absolute/path/to/agent
# OPENCURSOR_CURSOR_ACP_BIN=/absolute/path/to/agent
# OpenCode ACP: explicit binary, or rely on PATH / ~/.opencode/bin/opencode (see OPENCURSOR_REAL_HOME)
# OPENCURSOR_OPENCODE_ACP_BIN=/absolute/path/to/opencode
# When the server runs with a different $HOME (Docker/systemd), point at the real user home for ~/.opencode lookup.
# OPENCURSOR_REAL_HOME=/home/youruser
# OPENCURSOR_CURSOR_AGENT_ARGS=[]
# OPENCURSOR_CURSOR_PERMISSION_MODE=default
# Gemini CLI ACP (see repo root `.env.example`):
# OPENCURSOR_GEMINI_CLI_BIN=/absolute/path/to/gemini
# OPENCURSOR_GEMINI_CLI_ARGS=["--acp"]
# OPENCURSOR_CODEX_BIN=/absolute/path/to/codex
# OPENCURSOR_CLAUDE_BIN=/absolute/path/to/claude
# OPENCURSOR_ACP_CLIENT_CAPABILITIES_JSON={"terminal":true}
# OPENCURSOR_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# OPENCURSOR_TRANSCRIPTION_API_KEY=<secret>
# OPENCURSOR_TRANSCRIPTION_MODEL=<transcription-model-id>
# Or mount JSON (survives git-only deploy): see server/transcription-provider.json.example
# OPENCURSOR_TRANSCRIPTION_CONFIG_FILE=/run/secrets/transcription-provider.json
# Or one secret string (JSON object) for PaaS/Kubernetes:
# OPENCURSOR_TRANSCRIPTION_CONFIG_JSON={"baseUrl":"https://api.groq.com/openai/v1","apiKey":"…","model":"whisper-large-v3"}
# OPENCURSOR_TRANSCRIPTION_LANGUAGE=en
# OPENCURSOR_TRANSCRIPTION_PROMPT=

# Agent handoff: number of recent message pairs to include when handing off to a different agent (default: 25)
# OPENCURSOR_AGENT_HANDOFF_MESSAGE_LIMIT=25

# -----------------------------------------------------------------------------
# Storage backend (OSP-75)
# -----------------------------------------------------------------------------
# Driver resolution:
#   1. If OPENCURSOR_STORAGE_DRIVER is set, it always wins (opt-in override).
#   2. Else if DATABASE_URL is set, the "pg" driver is used (Phase 6 default).
#   3. Else the legacy JSON/JSONL driver is used so a fresh clone still works
#      with zero external services.
#
# To keep the legacy driver after configuring DATABASE_URL, set this explicitly:
# OPENCURSOR_STORAGE_DRIVER=legacy-json
#
# Postgres connection string. Matches the defaults baked into docker-compose.yml
# at the repo root (`docker compose up -d` + `npm run db:migrate` brings it up).
DATABASE_URL=postgres://opencursor:opencursor@localhost:5433/opencursor
# DATABASE_POOL_MAX=10
# DATABASE_IDLE_TIMEOUT_SEC=20
# DATABASE_CONNECT_TIMEOUT_SEC=10
#
# Redis is optional. When unset, pub/sub, KV cache, and rate limiting fall back
# to in-process implementations (EventEmitter / Map). Configure it for multi-
# process deployments or to share cache between the HTTP server and workers.
# REDIS_URL=redis://localhost:6380
# OPENCURSOR_REDIS_DEBUG=0
#
# First-boot helper:
# When the pg driver is active but a legacy data directory still exists on
# disk, the server prints a one-time banner on boot pointing at the migration
# tool. To migrate manually:
#   npm --prefix server run storage:migrate -- --from legacy-json --to pg
# To inspect both drivers without migrating:
#   npm --prefix server run storage:stats
