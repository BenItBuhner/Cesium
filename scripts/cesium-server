#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local target="${BASH_SOURCE[0]}"
  while [[ -L "$target" ]]; do
    local directory
    directory="$(cd -P "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" = /* ]] || target="$directory/$target"
  done
  cd -P "$(dirname "$target")" && pwd
}

CESIUM_HOME="${CESIUM_HOME:-$(cd "$(resolve_script_path)/.." && pwd)}"
ENV_FILE="$CESIUM_HOME/server.env"

if [[ ! -f "$ENV_FILE" ]]; then
  printf 'Cesium server configuration is missing: %s\n' "$ENV_FILE" >&2
  printf 'Run the Cesium server installer again.\n' >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

SOURCE_DIR="${CESIUM_SOURCE_DIR:-$CESIUM_HOME/source}"
RUN_DIR="$CESIUM_HOME/run"
LOG_DIR="$CESIUM_HOME/logs"
SERVER_PID_FILE="$RUN_DIR/server.pid"
TUNNEL_PID_FILE="$RUN_DIR/tunnel.pid"
PUBLIC_URL_FILE="$RUN_DIR/public-url"
SERVER_LOG="$LOG_DIR/server.log"
TUNNEL_LOG="$LOG_DIR/tunnel.log"
LOCAL_URL="http://${HOST:-127.0.0.1}:${PORT:-9100}"
BUN_BIN="${CESIUM_BUN_BIN:-$CESIUM_HOME/runtime/bin/bun}"
CLOUDFLARED_BIN="${CESIUM_CLOUDFLARED_BIN:-$CESIUM_HOME/runtime/bin/cloudflared}"

mkdir -p "$RUN_DIR" "$LOG_DIR"

read_pid() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  local pid
  pid="$(tr -d '[:space:]' <"$file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s' "$pid"
}

managed_process_is_running() {
  local file="$1"
  local expected="$2"
  local pid
  pid="$(read_pid "$file")" || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  local command
  command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ "$command" == *"$expected"* ]]
}

wait_for_health() {
  local attempt
  for ((attempt = 1; attempt <= 60; attempt++)); do
    if curl -fsS "$LOCAL_URL/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

start_server() {
  if managed_process_is_running "$SERVER_PID_FILE" "$SOURCE_DIR/server/src/runtime/bun-server.ts"; then
    return 0
  fi
  rm -f "$SERVER_PID_FILE"
  if [[ ! -x "$BUN_BIN" ]]; then
    printf 'Bun runtime is missing: %s\n' "$BUN_BIN" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    exit 1
  fi
  if [[ ! -f "$SOURCE_DIR/server/src/runtime/bun-server.ts" ]]; then
    printf 'Cesium server source is missing: %s\n' "$SOURCE_DIR" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    exit 1
  fi

  (
    cd "$SOURCE_DIR"
    nohup "$BUN_BIN" server/src/runtime/bun-server.ts >>"$SERVER_LOG" 2>&1 </dev/null &
    printf '%s\n' "$!" >"$SERVER_PID_FILE"
  )

  if ! wait_for_health; then
    printf 'Cesium server did not become healthy at %s.\n' "$LOCAL_URL" >&2
    printf 'Inspect the log with: cesium-server logs\n' >&2
    return 1
  fi
}

discover_quick_tunnel_url() {
  local attempt
  for ((attempt = 1; attempt <= 60; attempt++)); do
    local candidate
    candidate="$(
      awk 'match($0, /https:\/\/[-a-z0-9]+\.trycloudflare\.com/) {
        print substr($0, RSTART, RLENGTH)
        exit
      }' "$TUNNEL_LOG" 2>/dev/null || true
    )"
    if [[ -n "$candidate" ]]; then
      printf '%s\n' "$candidate" >"$PUBLIC_URL_FILE"
      printf '%s' "$candidate"
      return 0
    fi
    if ! managed_process_is_running "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN"; then
      return 1
    fi
    sleep 1
  done
  return 1
}

wait_for_public_health() {
  local remote="$1"
  local attempt
  for ((attempt = 1; attempt <= 30; attempt++)); do
    if curl -fsS "$remote/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

start_tunnel() {
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" != "1" ]]; then
    return 0
  fi
  if managed_process_is_running "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN"; then
    return 0
  fi
  rm -f "$TUNNEL_PID_FILE" "$PUBLIC_URL_FILE"
  if [[ ! -x "$CLOUDFLARED_BIN" ]]; then
    printf 'cloudflared is missing: %s\n' "$CLOUDFLARED_BIN" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    return 1
  fi
  : >"$TUNNEL_LOG"

  if [[ -n "${CESIUM_TUNNEL_TOKEN:-}" ]]; then
    if [[ -z "${CESIUM_PUBLIC_URL:-}" ]]; then
      printf 'CESIUM_PUBLIC_URL is required with CESIUM_TUNNEL_TOKEN.\n' >&2
      return 1
    fi
    nohup "$CLOUDFLARED_BIN" tunnel --no-autoupdate run \
      --token "$CESIUM_TUNNEL_TOKEN" >>"$TUNNEL_LOG" 2>&1 </dev/null &
    printf '%s\n' "$!" >"$TUNNEL_PID_FILE"
    printf '%s\n' "${CESIUM_PUBLIC_URL%/}" >"$PUBLIC_URL_FILE"
    sleep 2
    if ! managed_process_is_running "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN"; then
      printf 'The configured Cloudflare tunnel failed to start.\n' >&2
      return 1
    fi
    if ! wait_for_public_health "${CESIUM_PUBLIC_URL%/}"; then
      printf 'The configured Cloudflare tunnel is running, but its public health check failed.\n' >&2
      return 1
    fi
    return 0
  fi

  nohup "$CLOUDFLARED_BIN" tunnel --no-autoupdate \
    --url "$LOCAL_URL" >>"$TUNNEL_LOG" 2>&1 </dev/null &
  printf '%s\n' "$!" >"$TUNNEL_PID_FILE"
  if ! discover_quick_tunnel_url >/dev/null; then
    printf 'Cloudflare Quick Tunnel did not publish a URL.\n' >&2
    printf 'Inspect the tunnel log with: cesium-server logs tunnel\n' >&2
    return 1
  fi
  local remote
  remote="$(public_url)"
  if ! wait_for_public_health "$remote"; then
    printf 'Cloudflare Quick Tunnel published %s, but its health check failed.\n' "$remote" >&2
    return 1
  fi
}

stop_managed_process() {
  local file="$1"
  local expected="$2"
  local label="$3"
  local pid
  pid="$(read_pid "$file")" || {
    rm -f "$file"
    return 0
  }
  if ! managed_process_is_running "$file" "$expected"; then
    rm -f "$file"
    return 0
  fi
  kill "$pid"
  local attempt
  for ((attempt = 1; attempt <= 20; attempt++)); do
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$file"
      return 0
    fi
    sleep 0.25
  done
  printf '%s process %s did not stop cleanly.\n' "$label" "$pid" >&2
  return 1
}

stop_all() {
  stop_managed_process "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN" "Tunnel"
  stop_managed_process "$SERVER_PID_FILE" "$SOURCE_DIR/server/src/runtime/bun-server.ts" "Server"
  rm -f "$PUBLIC_URL_FILE"
}

public_url() {
  [[ -f "$PUBLIC_URL_FILE" ]] || return 1
  local value
  value="$(tr -d '[:space:]' <"$PUBLIC_URL_FILE")"
  [[ "$value" =~ ^https:// ]] || return 1
  printf '%s' "${value%/}"
}

encoded_public_url() {
  local value="$1"
  value="${value//%/%25}"
  value="${value//:/%3A}"
  value="${value//\//%2F}"
  printf '%s' "$value"
}

print_connection_details() {
  printf '\nCesium server is running.\n'
  printf 'Local URL: %s\n' "$LOCAL_URL"
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" == "1" ]]; then
    local remote
    remote="$(public_url)" || {
      printf 'Public tunnel: starting; run cesium-server connect shortly.\n'
      return 0
    }
    printf 'Public URL: %s\n' "$remote"
    if [[ -n "${CESIUM_WEB_URL:-}" ]]; then
      local separator="?"
      [[ "$CESIUM_WEB_URL" == *"?"* ]] && separator="&"
      printf 'Connect: %s%sserverUrl=%s\n' \
        "${CESIUM_WEB_URL%/}" "$separator" "$(encoded_public_url "$remote")"
    fi
  fi
  if [[ -n "${OPENCURSOR_AUTH_USERNAME:-}" ]]; then
    printf 'Username: %s\n' "$OPENCURSOR_AUTH_USERNAME"
    printf 'Password: %s\n' "$OPENCURSOR_AUTH_PASSWORD"
  fi
  printf 'Workspace: %s\n' "${WORKSPACE_ROOT:-}"
}

status() {
  if managed_process_is_running "$SERVER_PID_FILE" "$SOURCE_DIR/server/src/runtime/bun-server.ts" &&
    curl -fsS "$LOCAL_URL/health" >/dev/null 2>&1; then
    printf 'Server: running (%s)\n' "$LOCAL_URL"
  else
    printf 'Server: stopped\n'
  fi
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" == "1" ]]; then
    if managed_process_is_running "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN"; then
      printf 'Tunnel: running'
      local remote
      remote="$(public_url || true)"
      [[ -n "$remote" ]] && printf ' (%s)' "$remote"
      printf '\n'
    else
      printf 'Tunnel: stopped\n'
    fi
  fi
}

show_logs() {
  local target="${1:-server}"
  case "$target" in
    server) tail -n 100 -f "$SERVER_LOG" ;;
    tunnel) tail -n 100 -f "$TUNNEL_LOG" ;;
    *) printf 'Usage: cesium-server logs [server|tunnel]\n' >&2; exit 2 ;;
  esac
}

update_install() {
  stop_all
  if [[ ! -x "$SOURCE_DIR/scripts/install-cesium-server.sh" ]]; then
    printf 'Installer is missing from %s.\n' "$SOURCE_DIR" >&2
    exit 1
  fi
  CESIUM_HOME="$CESIUM_HOME" \
    CESIUM_WEB_URL="${CESIUM_WEB_URL:-}" \
    CESIUM_PORT="${PORT:-9100}" \
    CESIUM_STATE_DIR="${OPENCURSOR_DATA_DIR:-$CESIUM_HOME/state}" \
    CESIUM_WORKSPACE_ROOT="${WORKSPACE_ROOT:-$HOME}" \
    CESIUM_AUTH_USERNAME="${OPENCURSOR_AUTH_USERNAME:-cesium}" \
    CESIUM_AUTH_PASSWORD="${OPENCURSOR_AUTH_PASSWORD:-}" \
    CESIUM_TUNNEL_TOKEN="${CESIUM_TUNNEL_TOKEN:-}" \
    CESIUM_PUBLIC_URL="${CESIUM_PUBLIC_URL:-}" \
    exec "$SOURCE_DIR/scripts/install-cesium-server.sh"
}

case "${1:-status}" in
  run | start)
    start_server
    start_tunnel
    print_connection_details
    ;;
  stop)
    stop_all
    printf 'Cesium server stopped.\n'
    ;;
  restart)
    stop_all
    start_server
    start_tunnel
    print_connection_details
    ;;
  status)
    status
    ;;
  health)
    curl -fsS "$LOCAL_URL/health"
    printf '\n'
    ;;
  connect)
    print_connection_details
    ;;
  credentials)
    printf 'Username: %s\nPassword: %s\n' \
      "${OPENCURSOR_AUTH_USERNAME:-}" "${OPENCURSOR_AUTH_PASSWORD:-}"
    ;;
  logs)
    show_logs "${2:-server}"
    ;;
  update)
    update_install
    ;;
  *)
    printf 'Usage: cesium-server {run|stop|restart|status|health|connect|credentials|logs [server|tunnel]|update}\n' >&2
    exit 2
    ;;
esac
