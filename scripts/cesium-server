#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local target="${BASH_SOURCE[0]}"
  while [[ -L "$target" ]]; do
    local directory
    directory="$(cd -P "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" = /* ]] || target="$directory/$target"
  done
  cd -P "$(dirname "$target")" && pwd
}

CESIUM_HOME="${CESIUM_HOME:-$(cd "$(resolve_script_path)/.." && pwd)}"
ENV_FILE="$CESIUM_HOME/server.env"

if [[ ! -f "$ENV_FILE" ]]; then
  printf 'Cesium server configuration is missing: %s\n' "$ENV_FILE" >&2
  printf 'Run the Cesium server installer again.\n' >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

SOURCE_DIR="${CESIUM_SOURCE_DIR:-$CESIUM_HOME/source}"
RUN_DIR="$CESIUM_HOME/run"
LOG_DIR="$CESIUM_HOME/logs"
SERVER_PID_FILE="$RUN_DIR/server.pid"
TUNNEL_PID_FILE="$RUN_DIR/tunnel.pid"
SUPERVISOR_PID_FILE="$RUN_DIR/supervisor.pid"
SUPERVISOR_LOCK_DIR="$RUN_DIR/supervisor.lock"
TUNNEL_PROVIDER_FILE="$RUN_DIR/tunnel-provider"
PUBLIC_URL_FILE="$RUN_DIR/public-url"
RENDEZVOUS_STATUS_FILE="$RUN_DIR/rendezvous-status"
RENDEZVOUS_ERROR_FILE="$RUN_DIR/rendezvous-error"
SERVER_LOG="$LOG_DIR/server.log"
TUNNEL_LOG="$LOG_DIR/tunnel.log"
RENDEZVOUS_LOG="$LOG_DIR/rendezvous.log"
LOCAL_URL="http://${HOST:-127.0.0.1}:${PORT:-9100}"
BUN_BIN="${CESIUM_BUN_BIN:-$CESIUM_HOME/runtime/bin/bun}"
CLOUDFLARED_BIN="${CESIUM_CLOUDFLARED_BIN:-$CESIUM_HOME/runtime/bin/cloudflared}"
SSH_BIN="${CESIUM_SSH_BIN:-}"
SERVER_PROCESS_SIGNATURE="server/src/runtime/bun-server.ts"
SUPERVISOR_PROCESS_SIGNATURE="cesium-server supervise"
MANAGER_BIN="${CESIUM_MANAGER_BIN:-$CESIUM_HOME/bin/cesium-server}"
RENDEZVOUS_HELPER="$SOURCE_DIR/scripts/cesium-rendezvous.mjs"
PUBLIC_HEALTH_TIMEOUT="${CESIUM_PUBLIC_HEALTH_TIMEOUT:-120}"
TUNNEL_URL_TIMEOUT="${CESIUM_TUNNEL_URL_TIMEOUT:-60}"

mkdir -p "$RUN_DIR" "$LOG_DIR"

if [[ ! "$PUBLIC_HEALTH_TIMEOUT" =~ ^[0-9]+$ ]] || ((PUBLIC_HEALTH_TIMEOUT < 1)); then
  PUBLIC_HEALTH_TIMEOUT=120
fi
if [[ ! "$TUNNEL_URL_TIMEOUT" =~ ^[0-9]+$ ]] || ((TUNNEL_URL_TIMEOUT < 1)); then
  TUNNEL_URL_TIMEOUT=60
fi

read_pid() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  local pid
  pid="$(tr -d '[:space:]' <"$file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s' "$pid"
}

managed_process_is_running() {
  local file="$1"
  local expected="$2"
  local pid
  pid="$(read_pid "$file")" || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  local command
  command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ "$command" == *"$expected"* ]]
}

wait_for_health() {
  local attempt
  for ((attempt = 1; attempt <= 60; attempt++)); do
    if curl -fsS --max-time 5 "$LOCAL_URL/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

backend_manages_public_access() {
  [[ "${CESIUM_BACKEND_MANAGES_PUBLIC_ACCESS:-0}" == "1" ]]
}

tunnel_required() {
  if backend_manages_public_access &&
    [[ -f "$RUN_DIR/backend-public-access-disabled" ]]; then
    return 1
  fi
  [[ "${CESIUM_TUNNEL_REQUIRED:-0}" == "1" ]]
}

find_ssh() {
  if [[ -n "$SSH_BIN" && -x "$SSH_BIN" ]]; then
    printf '%s' "$SSH_BIN"
    return 0
  fi
  command -v ssh 2>/dev/null
}

resolve_tunnel_provider() {
  if [[ -n "${CESIUM_TUNNEL_TOKEN:-}" ]]; then
    printf 'cloudflare-named'
    return 0
  fi

  local configured="${CESIUM_TUNNEL_PROVIDER:-auto}"
  case "$configured" in
    auto | localhost-run)
      if find_ssh >/dev/null; then
        printf 'localhost-run'
      else
        printf 'cloudflare-quick'
      fi
      ;;
    cloudflare-quick)
      printf 'cloudflare-quick'
      ;;
    *)
      printf 'Unsupported tunnel provider: %s\n' "$configured" >&2
      return 1
      ;;
  esac
}

active_tunnel_provider() {
  if [[ -f "$TUNNEL_PROVIDER_FILE" ]]; then
    local provider
    provider="$(tr -d '[:space:]' <"$TUNNEL_PROVIDER_FILE")"
    case "$provider" in
      cloudflare-named | cloudflare-quick | localhost-run)
        printf '%s' "$provider"
        return 0
        ;;
    esac
  fi
  if managed_process_is_running "$TUNNEL_PID_FILE" "$CLOUDFLARED_BIN"; then
    printf 'cloudflare-quick'
    return 0
  fi
  return 1
}

tunnel_process_signature() {
  case "$1" in
    cloudflare-named | cloudflare-quick) printf '%s' "$CLOUDFLARED_BIN" ;;
    localhost-run) printf 'localhost.run' ;;
    *) return 1 ;;
  esac
}

tunnel_is_running() {
  local provider signature
  provider="$(active_tunnel_provider)" || return 1
  signature="$(tunnel_process_signature "$provider")" || return 1
  managed_process_is_running "$TUNNEL_PID_FILE" "$signature"
}

start_server() {
  if managed_process_is_running "$SERVER_PID_FILE" "$SERVER_PROCESS_SIGNATURE"; then
    return 0
  fi
  rm -f "$SERVER_PID_FILE"
  if [[ ! -x "$BUN_BIN" ]]; then
    printf 'Bun runtime is missing: %s\n' "$BUN_BIN" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    exit 1
  fi
  if [[ ! -f "$SOURCE_DIR/server/src/runtime/bun-server.ts" ]]; then
    printf 'Cesium server source is missing: %s\n' "$SOURCE_DIR" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    exit 1
  fi

  (
    cd "$SOURCE_DIR"
    nohup "$BUN_BIN" server/src/runtime/bun-server.ts >>"$SERVER_LOG" 2>&1 </dev/null &
    printf '%s\n' "$!" >"$SERVER_PID_FILE"
  )

  if ! wait_for_health; then
    printf 'Cesium server did not become healthy at %s.\n' "$LOCAL_URL" >&2
    printf 'Inspect the log with: cesium-server logs\n' >&2
    return 1
  fi
}

extract_tunnel_url() {
  local provider="$1"
  local candidate=""
  case "$provider" in
    cloudflare-quick)
      candidate="$(awk 'match($0, /https:\/\/[-a-z0-9]+\.trycloudflare\.com/) {
        candidate = substr($0, RSTART, RLENGTH)
      }
      END {
        if (candidate != "") print candidate
      }' "$TUNNEL_LOG" 2>/dev/null)"
      ;;
    localhost-run)
      candidate="$(awk 'match($0, /https:\/\/[-a-z0-9]+\.lhr\.life/) {
        candidate = substr($0, RSTART, RLENGTH)
      }
      END {
        if (candidate != "") print candidate
      }' "$TUNNEL_LOG" 2>/dev/null)"
      ;;
    *)
      return 1
      ;;
  esac
  printf '%s' "$candidate"
}

discover_tunnel_url() {
  local provider="$1"
  local attempt
  for ((attempt = 1; attempt <= TUNNEL_URL_TIMEOUT; attempt++)); do
    local candidate
    candidate="$(extract_tunnel_url "$provider" || true)"
    if [[ -n "$candidate" ]]; then
      printf '%s' "$candidate"
      return 0
    fi
    if ! tunnel_is_running; then
      return 1
    fi
    sleep 1
  done
  return 1
}

public_hostname() {
  local remote="${1#https://}"
  printf '%s' "${remote%%/*}"
}

describe_public_dns() {
  local remote="$1"
  local hostname
  hostname="$(public_hostname "$remote")"
  if command -v dig >/dev/null 2>&1; then
    local status
    status="$(dig +time=3 +tries=1 "$hostname" A 2>/dev/null | awk '
      /status:/ {
        sub(/^.*status: /, "")
        sub(/,.*/, "")
        print
        exit
      }' || true)"
    [[ -n "$status" ]] && printf 'DNS status for %s: %s\n' "$hostname" "$status"
    return 0
  fi
  if getent hosts "$hostname" >/dev/null 2>&1; then
    printf 'DNS resolved for %s.\n' "$hostname"
  else
    printf 'DNS did not resolve for %s.\n' "$hostname"
  fi
}

public_health_is_healthy() {
  local remote="$1"
  local output
  output="$(curl -fsS --connect-timeout 5 --max-time 10 "$remote/health" 2>/dev/null)" &&
    [[ "$output" == *'"ok":true'* ]]
}

wait_for_public_health() {
  local remote="$1"
  local attempt last_error=""
  for ((attempt = 1; attempt <= PUBLIC_HEALTH_TIMEOUT; attempt++)); do
    local output
    if output="$(curl -fsS --connect-timeout 5 --max-time 10 "$remote/health" 2>&1)"; then
      if [[ "$output" == *'"ok":true'* ]]; then
        return 0
      fi
      last_error="HTTP 200 did not contain the Cesium health payload"
    else
      last_error="$output"
    fi
    sleep 1
  done
  printf 'Last public health error: %s\n' "${last_error:-unknown error}" >&2
  describe_public_dns "$remote" >&2
  return 1
}

stop_tunnel() {
  local provider signature
  provider="$(active_tunnel_provider || true)"
  if [[ -n "$provider" ]]; then
    signature="$(tunnel_process_signature "$provider")"
    stop_managed_process "$TUNNEL_PID_FILE" "$signature" "Tunnel"
  else
    rm -f "$TUNNEL_PID_FILE"
  fi
  rm -f "$PUBLIC_URL_FILE" "$TUNNEL_PROVIDER_FILE"
}

require_cloudflared() {
  if [[ ! -x "$CLOUDFLARED_BIN" ]]; then
    printf 'cloudflared is missing: %s\n' "$CLOUDFLARED_BIN" >&2
    printf 'Run the Cesium server installer again.\n' >&2
    return 1
  fi
}

start_cloudflare_named_tunnel() {
  require_cloudflared || return 1
  if [[ -z "${CESIUM_PUBLIC_URL:-}" ]]; then
    printf 'CESIUM_PUBLIC_URL is required with CESIUM_TUNNEL_TOKEN.\n' >&2
    return 1
  fi
  printf '%s\n' "cloudflare-named" >"$TUNNEL_PROVIDER_FILE"
  nohup "$CLOUDFLARED_BIN" tunnel --no-autoupdate run \
    --token "$CESIUM_TUNNEL_TOKEN" >>"$TUNNEL_LOG" 2>&1 </dev/null &
  printf '%s\n' "$!" >"$TUNNEL_PID_FILE"
  sleep 2
  if ! tunnel_is_running; then
    printf 'The configured Cloudflare tunnel failed to start.\n' >&2
    stop_tunnel
    return 1
  fi
  local remote="${CESIUM_PUBLIC_URL%/}"
  if ! wait_for_public_health "$remote"; then
    printf 'The configured Cloudflare tunnel is running, but its public health check failed.\n' >&2
    stop_tunnel
    return 1
  fi
  printf '%s\n' "$remote" >"$PUBLIC_URL_FILE"
}

start_cloudflare_quick_tunnel() {
  require_cloudflared || return 1
  printf '%s\n' "cloudflare-quick" >"$TUNNEL_PROVIDER_FILE"
  nohup "$CLOUDFLARED_BIN" tunnel --no-autoupdate \
    --url "$LOCAL_URL" >>"$TUNNEL_LOG" 2>&1 </dev/null &
  printf '%s\n' "$!" >"$TUNNEL_PID_FILE"
  local remote
  if ! remote="$(discover_tunnel_url cloudflare-quick)"; then
    printf 'Cloudflare Quick Tunnel did not publish a URL.\n' >&2
    printf 'Inspect the tunnel log with: cesium-server logs tunnel\n' >&2
    stop_tunnel
    return 1
  fi
  if ! wait_for_public_health "$remote"; then
    printf 'Cloudflare Quick Tunnel published %s, but its health check failed.\n' "$remote" >&2
    stop_tunnel
    return 1
  fi
  printf '%s\n' "$remote" >"$PUBLIC_URL_FILE"
}

start_localhost_run_tunnel() {
  local ssh_command
  ssh_command="$(find_ssh)" || {
    printf 'ssh is unavailable; falling back to Cloudflare Quick Tunnel.\n' >&2
    start_cloudflare_quick_tunnel
    return
  }
  printf '%s\n' "localhost-run" >"$TUNNEL_PROVIDER_FILE"
  nohup "$ssh_command" \
    -o BatchMode=yes \
    -o ConnectTimeout=10 \
    -o StrictHostKeyChecking=accept-new \
    -o ExitOnForwardFailure=yes \
    -o ServerAliveInterval=30 \
    -o ServerAliveCountMax=3 \
    -R "80:${HOST:-127.0.0.1}:${PORT:-9100}" \
    nokey@localhost.run >>"$TUNNEL_LOG" 2>&1 </dev/null &
  printf '%s\n' "$!" >"$TUNNEL_PID_FILE"

  local remote
  if ! remote="$(discover_tunnel_url localhost-run)"; then
    printf 'localhost.run did not publish a URL.\n' >&2
    printf 'Inspect the tunnel log with: cesium-server logs tunnel\n' >&2
    stop_tunnel
    return 1
  fi
  if ! wait_for_public_health "$remote"; then
    printf 'localhost.run published %s, but its health check failed.\n' "$remote" >&2
    stop_tunnel
    return 1
  fi
  printf '%s\n' "$remote" >"$PUBLIC_URL_FILE"
}

start_tunnel() {
  if backend_manages_public_access; then
    return 0
  fi
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" != "1" ]]; then
    return 0
  fi
  if tunnel_is_running; then
    return 0
  fi
  rm -f "$TUNNEL_PID_FILE" "$PUBLIC_URL_FILE" "$TUNNEL_PROVIDER_FILE"

  local provider
  provider="$(resolve_tunnel_provider)" || return 1
  printf 'Starting tunnel provider: %s\n' "$provider" >"$TUNNEL_LOG"
  case "$provider" in
    cloudflare-named) start_cloudflare_named_tunnel ;;
    cloudflare-quick) start_cloudflare_quick_tunnel ;;
    localhost-run) start_localhost_run_tunnel ;;
  esac
}

stop_managed_process() {
  local file="$1"
  local expected="$2"
  local label="$3"
  local pid
  pid="$(read_pid "$file")" || {
    rm -f "$file"
    return 0
  }
  if ! managed_process_is_running "$file" "$expected"; then
    rm -f "$file"
    return 0
  fi
  kill "$pid"
  local attempt
  for ((attempt = 1; attempt <= 20; attempt++)); do
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$file"
      return 0
    fi
    sleep 0.25
  done
  printf '%s process %s did not stop cleanly.\n' "$label" "$pid" >&2
  return 1
}

stop_all() {
  stop_tunnel
  stop_managed_process "$SERVER_PID_FILE" "$SERVER_PROCESS_SIGNATURE" "Server"
}

refresh_public_url() {
  tunnel_is_running || return 0

  local provider
  provider="$(active_tunnel_provider)" || return 0
  case "$provider" in
    cloudflare-quick | localhost-run) ;;
    *) return 0 ;;
  esac

  local candidate current=""
  candidate="$(extract_tunnel_url "$provider" || true)"
  [[ -n "$candidate" ]] || return 0
  if [[ -f "$PUBLIC_URL_FILE" ]]; then
    current="$(tr -d '[:space:]' <"$PUBLIC_URL_FILE")"
  fi
  [[ "$candidate" != "$current" ]] || return 0

  local healthy=0
  public_health_is_healthy "$candidate" && healthy=1
  ((healthy == 1)) || return 0

  local temporary_file="${PUBLIC_URL_FILE}.tmp.$$"
  printf '%s\n' "$candidate" >"$temporary_file"
  mv "$temporary_file" "$PUBLIC_URL_FILE"
}

public_url() {
  refresh_public_url
  [[ -f "$PUBLIC_URL_FILE" ]] || return 1
  local value
  value="$(tr -d '[:space:]' <"$PUBLIC_URL_FILE")"
  [[ "$value" =~ ^https:// ]] || return 1
  printf '%s' "${value%/}"
}

publish_rendezvous() {
  if backend_manages_public_access; then
    return 0
  fi
  if [[ -z "${CESIUM_RENDEZVOUS_URL:-}" ]]; then
    [[ "${CESIUM_RENDEZVOUS_REQUIRED:-0}" != "1" ]]
    return
  fi
  if [[ ! -f "$RENDEZVOUS_HELPER" ]]; then
    printf 'Rendezvous helper is missing: %s\n' "$RENDEZVOUS_HELPER" >&2
    return 1
  fi
  local remote provider
  remote="$(public_url)" || return 1
  provider="$(active_tunnel_provider || true)"
  local output
  if output="$("$BUN_BIN" "$RENDEZVOUS_HELPER" publish "$remote" "$provider" 2>&1)"; then
    [[ -n "$output" ]] && printf '%s\n' "$output" >>"$RENDEZVOUS_LOG"
    local temporary_file="${RENDEZVOUS_STATUS_FILE}.tmp.$$"
    printf '%s\t%s\n' "$(date +%s)" "$remote" >"$temporary_file"
    mv "$temporary_file" "$RENDEZVOUS_STATUS_FILE"
    rm -f "$RENDEZVOUS_ERROR_FILE"
    return 0
  fi
  printf '%s\n' "$output" >>"$RENDEZVOUS_LOG"
  printf '%s\n' "${output:-Rendezvous publish failed.}" >"$RENDEZVOUS_ERROR_FILE"
  return 1
}

rendezvous_is_ready() {
  [[ -f "$RENDEZVOUS_STATUS_FILE" ]] || return 1
  local published_at published_url current_url now
  IFS=$'\t' read -r published_at published_url <"$RENDEZVOUS_STATUS_FILE" || return 1
  [[ "$published_at" =~ ^[0-9]+$ ]] || return 1
  current_url="$(public_url)" || return 1
  [[ "$published_url" == "$current_url" ]] || return 1
  now="$(date +%s)"
  ((now - published_at < 75))
}

stable_connect_url() {
  [[ -n "${CESIUM_WEB_URL:-}" && -n "${CESIUM_RENDEZVOUS_URL:-}" ]] || return 1
  rendezvous_is_ready || return 1
  local remote fragment
  remote="$(public_url)" || return 1
  fragment="$("$BUN_BIN" "$RENDEZVOUS_HELPER" connect-fragment "$remote")" || return 1
  printf '%s/agent#cesiumConnect=%s' "${CESIUM_WEB_URL%/}" "$fragment"
}

encoded_public_url() {
  local value="$1"
  value="${value//%/%25}"
  value="${value//:/%3A}"
  value="${value//\//%2F}"
  printf '%s' "$value"
}

print_connection_details() {
  printf '\nCesium server is running.\n'
  printf 'Local URL: %s\n' "$LOCAL_URL"
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" == "1" ]]; then
    local remote
    remote="$(public_url)" || {
      printf 'Public tunnel: unavailable; run cesium-server run to retry.\n'
      return 0
    }
    printf 'Public URL: %s\n' "$remote"
    if [[ -n "${CESIUM_WEB_URL:-}" ]]; then
      local stable_url
      stable_url="$(stable_connect_url || true)"
      if [[ -n "$stable_url" ]]; then
        printf 'Connect: %s\n' "$stable_url"
      else
        local separator="?"
        [[ "$CESIUM_WEB_URL" == *"?"* ]] && separator="&"
        printf 'Connect: %s%sserverUrl=%s\n' \
          "${CESIUM_WEB_URL%/}" "$separator" "$(encoded_public_url "$remote")"
      fi
    fi
  fi
  if [[ -n "${OPENCURSOR_AUTH_USERNAME:-}" ]]; then
    printf 'Username: %s\n' "$OPENCURSOR_AUTH_USERNAME"
    printf 'Password: %s\n' "$OPENCURSOR_AUTH_PASSWORD"
  fi
  printf 'Workspace: %s\n' "${WORKSPACE_ROOT:-}"
}

status() {
  if supervisor_is_running; then
    printf 'Lifecycle: running (%s)\n' "${CESIUM_SERVICE_MANAGER:-detached}"
  else
    printf 'Lifecycle: stopped (%s)\n' "${CESIUM_SERVICE_MANAGER:-detached}"
  fi
  if managed_process_is_running "$SERVER_PID_FILE" "$SERVER_PROCESS_SIGNATURE" &&
    curl -fsS "$LOCAL_URL/health" >/dev/null 2>&1; then
    printf 'Server: running (%s)\n' "$LOCAL_URL"
  else
    printf 'Server: stopped\n'
  fi
  if [[ "${CESIUM_TUNNEL_ENABLED:-0}" == "1" ]]; then
    if backend_manages_public_access; then
      local backend_url
      backend_url="$(public_url || true)"
      if [[ -n "$backend_url" ]]; then
        printf 'Tunnel: running (backend-managed, %s)\n' "$backend_url"
      elif [[ -f "$RUN_DIR/backend-public-access-disabled" ]]; then
        printf 'Tunnel: disabled in Cesium settings\n'
      else
        printf 'Tunnel: starting (backend-managed)\n'
      fi
    elif tunnel_is_running; then
      local provider
      provider="$(active_tunnel_provider)"
      printf 'Tunnel: running (%s' "$provider"
      local remote
      remote="$(public_url || true)"
      [[ -n "$remote" ]] && printf ', %s' "$remote"
      printf ')\n'
    else
      printf 'Tunnel: stopped\n'
    fi
  fi
  if [[ -n "${CESIUM_RENDEZVOUS_URL:-}" ]]; then
    if rendezvous_is_ready; then
      printf 'Rendezvous: connected\n'
    else
      printf 'Rendezvous: waiting\n'
    fi
  fi
}

show_logs() {
  local target="${1:-server}"
  case "$target" in
    server) tail -n 100 -f "$SERVER_LOG" ;;
    tunnel) tail -n 100 -f "$TUNNEL_LOG" ;;
    rendezvous) tail -n 100 -f "$RENDEZVOUS_LOG" ;;
    supervisor) tail -n 100 -f "$LOG_DIR/supervisor.log" ;;
    *) printf 'Usage: cesium-server logs [server|tunnel|rendezvous|supervisor]\n' >&2; exit 2 ;;
  esac
}

supervisor_is_running() {
  managed_process_is_running "$SUPERVISOR_PID_FILE" "$SUPERVISOR_PROCESS_SIGNATURE"
}

cleanup_supervisor() {
  stop_all || true
  rm -f "$SUPERVISOR_PID_FILE"
  rmdir "$SUPERVISOR_LOCK_DIR" 2>/dev/null || true
}

supervise() {
  if ! mkdir "$SUPERVISOR_LOCK_DIR" 2>/dev/null; then
    if supervisor_is_running; then
      return 0
    fi
    rmdir "$SUPERVISOR_LOCK_DIR" 2>/dev/null || true
    mkdir "$SUPERVISOR_LOCK_DIR"
  fi
  printf '%s\n' "${BASHPID:-$$}" >"$SUPERVISOR_PID_FILE"
  trap cleanup_supervisor EXIT
  trap 'exit 0' INT TERM

  local last_published_at=0
  local last_published_url=""
  local tunnel_health_failures=0
  local interval="${CESIUM_RENDEZVOUS_INTERVAL:-15}"
  [[ "$interval" =~ ^[0-9]+$ ]] || interval=15
  ((interval >= 5)) || interval=5

  while true; do
    if managed_process_is_running "$SERVER_PID_FILE" "$SERVER_PROCESS_SIGNATURE" &&
      ! curl -fsS --max-time 5 "$LOCAL_URL/health" >/dev/null 2>&1; then
      stop_managed_process "$SERVER_PID_FILE" "$SERVER_PROCESS_SIGNATURE" "Server" || true
    fi
    if ! start_server; then
      printf '%s Server restart failed; retrying.\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >>"$RENDEZVOUS_LOG"
      sleep 5
      continue
    fi
    if ! start_tunnel; then
      printf '%s Tunnel restart failed; retrying.\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >>"$RENDEZVOUS_LOG"
      sleep 5
      continue
    fi
    refresh_public_url

    local remote="" now
    remote="$(public_url || true)"
    now="$(date +%s)"
    if tunnel_required && ! backend_manages_public_access; then
      if [[ -n "$remote" ]] && public_health_is_healthy "$remote"; then
        tunnel_health_failures=0
      else
        tunnel_health_failures=$((tunnel_health_failures + 1))
        if ((tunnel_health_failures >= 3)); then
          printf '%s Tunnel health failed repeatedly; restarting.\n' \
            "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >>"$RENDEZVOUS_LOG"
          stop_tunnel || true
          tunnel_health_failures=0
          last_published_url=""
          sleep 2
          continue
        fi
      fi
    fi
    if [[ -n "$remote" ]] &&
      { [[ "$remote" != "$last_published_url" ]] || ((now - last_published_at >= interval)); }; then
      if publish_rendezvous; then
        last_published_url="$remote"
        last_published_at="$now"
      elif [[ "${CESIUM_RENDEZVOUS_REQUIRED:-0}" == "1" ]]; then
        printf '%s Rendezvous publish failed; retrying.\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >>"$RENDEZVOUS_LOG"
      fi
    fi
    sleep 5
  done
}

start_managed_service() {
  case "${CESIUM_SERVICE_MANAGER:-detached}" in
    systemd-user)
      systemctl --user start cesium-server.service
      ;;
    launchd)
      local domain="gui/$(id -u)"
      local label="dev.cesium.server"
      local plist="$HOME/Library/LaunchAgents/$label.plist"
      if launchctl print "$domain/$label" >/dev/null 2>&1; then
        launchctl kickstart -k "$domain/$label"
      else
        launchctl bootstrap "$domain" "$plist"
      fi
      ;;
    detached)
      if ! supervisor_is_running; then
        nohup "$MANAGER_BIN" supervise >>"$LOG_DIR/supervisor.log" 2>&1 </dev/null &
      fi
      ;;
    *)
      printf 'Unsupported service manager: %s\n' "${CESIUM_SERVICE_MANAGER:-}" >&2
      return 1
      ;;
  esac
}

stop_managed_service() {
  case "${CESIUM_SERVICE_MANAGER:-detached}" in
    systemd-user)
      systemctl --user stop cesium-server.service 2>/dev/null || true
      ;;
    launchd)
      launchctl bootout "gui/$(id -u)/dev.cesium.server" 2>/dev/null || true
      ;;
    detached)
      if supervisor_is_running; then
        local pid
        pid="$(read_pid "$SUPERVISOR_PID_FILE")"
        kill "$pid"
        local attempt
        for ((attempt = 1; attempt <= 40; attempt++)); do
          kill -0 "$pid" 2>/dev/null || break
          sleep 0.25
        done
      fi
      ;;
  esac
  stop_all || true
  rm -f "$SUPERVISOR_PID_FILE"
  rmdir "$SUPERVISOR_LOCK_DIR" 2>/dev/null || true
}

wait_for_managed_ready() {
  local attempt
  for ((attempt = 1; attempt <= 90; attempt++)); do
    if curl -fsS "$LOCAL_URL/health" >/dev/null 2>&1; then
      local ready=1
      if tunnel_required && ! public_url >/dev/null 2>&1; then
        ready=0
      fi
      if [[ "${CESIUM_RENDEZVOUS_REQUIRED:-0}" == "1" ]] &&
        ! rendezvous_is_ready; then
        ready=0
      fi
      ((ready == 1)) && return 0
    fi
    sleep 1
  done
  return 1
}

update_install() {
  stop_managed_service
  if [[ ! -x "$SOURCE_DIR/scripts/install-cesium-server.sh" ]]; then
    printf 'Installer is missing from %s.\n' "$SOURCE_DIR" >&2
    exit 1
  fi
  CESIUM_HOME="$CESIUM_HOME" \
    CESIUM_WEB_URL="${CESIUM_WEB_URL:-}" \
    CESIUM_PORT="${PORT:-9100}" \
    CESIUM_STATE_DIR="${OPENCURSOR_DATA_DIR:-$CESIUM_HOME/state}" \
    CESIUM_WORKSPACE_ROOT="${WORKSPACE_ROOT:-$HOME}" \
    CESIUM_AUTH_USERNAME="${OPENCURSOR_AUTH_USERNAME:-cesium}" \
    CESIUM_AUTH_PASSWORD="${OPENCURSOR_AUTH_PASSWORD:-}" \
    CESIUM_SERVER_ID="${CESIUM_SERVER_ID:-}" \
    CESIUM_SERVER_LABEL="${CESIUM_SERVER_LABEL:-}" \
    CESIUM_RENDEZVOUS_URL="${CESIUM_RENDEZVOUS_URL:-}" \
    CESIUM_RENDEZVOUS_READ_SECRET="${CESIUM_RENDEZVOUS_READ_SECRET:-}" \
    CESIUM_RENDEZVOUS_WRITE_SECRET="${CESIUM_RENDEZVOUS_WRITE_SECRET:-}" \
    CESIUM_RENDEZVOUS_REQUIRED="${CESIUM_RENDEZVOUS_REQUIRED:-0}" \
    CESIUM_SERVICE_MANAGER="${CESIUM_SERVICE_MANAGER:-auto}" \
    CESIUM_TUNNEL_REQUIRED="${CESIUM_TUNNEL_REQUIRED:-0}" \
    CESIUM_TUNNEL_PROVIDER="${CESIUM_TUNNEL_PROVIDER:-auto}" \
    CESIUM_TUNNEL_TOKEN="${CESIUM_TUNNEL_TOKEN:-}" \
    CESIUM_PUBLIC_URL="${CESIUM_PUBLIC_URL:-}" \
    exec "$SOURCE_DIR/scripts/install-cesium-server.sh"
}

main() {
  case "${1:-status}" in
    run | start)
      start_managed_service
      if ! wait_for_managed_ready; then
        printf 'Cesium lifecycle started, but did not become fully ready.\n' >&2
        if [[ -f "$RENDEZVOUS_ERROR_FILE" ]]; then
          printf 'Rendezvous: %s\n' "$(tr '\n' ' ' <"$RENDEZVOUS_ERROR_FILE")" >&2
        fi
        printf 'Inspect: cesium-server logs server; cesium-server logs rendezvous\n' >&2
        return 1
      fi
      print_connection_details
      ;;
    stop)
      stop_managed_service
      printf 'Cesium server stopped.\n'
      ;;
    restart)
      stop_managed_service
      start_managed_service
      if ! wait_for_managed_ready; then
        printf 'Cesium lifecycle restarted, but did not become fully ready.\n' >&2
        return 1
      fi
      print_connection_details
      ;;
    supervise)
      supervise
      ;;
    status)
      status
      ;;
    health)
      curl -fsS "$LOCAL_URL/health"
      printf '\n'
      ;;
    connect)
      print_connection_details
      ;;
    credentials)
      printf 'Username: %s\nPassword: %s\n' \
        "${OPENCURSOR_AUTH_USERNAME:-}" "${OPENCURSOR_AUTH_PASSWORD:-}"
      ;;
    logs)
      show_logs "${2:-server}"
      ;;
    update)
      update_install
      ;;
    *)
      printf 'Usage: cesium-server {run|stop|restart|status|health|connect|credentials|logs [server|tunnel|rendezvous|supervisor]|update}\n' >&2
      exit 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
