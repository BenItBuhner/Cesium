# --- Next.js (browser) ---
NEXT_PUBLIC_SERVER_URL=http://localhost:9100

# --- Cesium server (Node) ---
# Loaded from repo root `.env.local` / `.env` when you run `npm run dev` in `server/`,
# or from `server/.env` if you prefer to keep secrets only under server/.
#
# Default workspace opened on first bootstrap. Must lie under an allowed root
# (see WORKSPACE_ALLOWED_ROOTS). If unset, the server uses the repo parent of `server/`.
WORKSPACE_ROOT=C:\Users\benpr\OneDrive\Documents\Projects\cesium

# Optional: comma-separated absolute directory paths workspace roots may live under.
# When set, ONLY these paths are allowed (no automatic repo-root fallback).
# WORKSPACE_ALLOWED_ROOTS=C:\Users\benpr\OneDrive\Documents\Projects

# Optional escape hatch (avoid in production):
# OPENCURSOR_ALLOW_ANY_WORKSPACE_ROOT=1

# Optional CLI overrides for additional agent backends:
# OPENCURSOR_CURSOR_CLI_BIN=/absolute/path/to/agent
# OPENCURSOR_CURSOR_ACP_BIN=/absolute/path/to/agent
# Optional argv after the binary (JSON array of strings), e.g. subcommands your build needs:
# OPENCURSOR_CURSOR_AGENT_ARGS=[]
# Shorthand for Cursor agent: pass-through to --permission-mode (see Cursor CLI docs for valid values):
# OPENCURSOR_CURSOR_PERMISSION_MODE=default
# Devin CLI ACP: `curl -fsSL https://cli.devin.ai/install.sh | bash` then `devin acp`, or set an explicit binary:
# OPENCURSOR_DEVIN_CLI_BIN=/absolute/path/to/devin
# Optional JSON argv for ACP (default: ["acp"]).
# OPENCURSOR_DEVIN_CLI_ARGS=["acp"]
# Optional Devin/Windsurf API key when `devin auth login` credentials are unavailable:
# WINDSURF_API_KEY=
# Google Antigravity CLI (successor to Gemini CLI): install `agy`, sign in with Google OAuth on the host, or set:
# OPENCURSOR_ANTIGRAVITY_CLI_BIN=/absolute/path/to/agy
# OPENCURSOR_AGY_BIN=/absolute/path/to/agy
# OPENCURSOR_CODEX_BIN=/absolute/path/to/codex
# OPENCURSOR_CLAUDE_BIN=/absolute/path/to/claude
#
# Optional JSON merged into ACP `initialize.clientCapabilities` (Devin / other ACP backends).
# Example if the CLI rejects tools until terminal delegation is advertised:
# OPENCURSOR_ACP_CLIENT_CAPABILITIES_JSON={"terminal":true}

# Optional speech-to-text provider for composer voice input.
# Uses an OpenAI-compatible multipart transcription endpoint, so this can point at
# OpenAI-style or Groq-compatible hosts.
# OPENCURSOR_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# OPENCURSOR_TRANSCRIPTION_API_KEY=<secret>
# OPENCURSOR_TRANSCRIPTION_MODEL=<transcription-model-id>
# OPENCURSOR_TRANSCRIPTION_LANGUAGE=en
# OPENCURSOR_TRANSCRIPTION_PROMPT=

# Optional Cesium Agent OpenAI-compatible host bootstrap (chat — not transcription).
# When BASE_URL points at a non-OpenAI host, Cesium registers an env provider with
# default models glm-5.2 (text) and kimi-k2.7-code (multimodal / images).
# CESIUM_BASE_URL=https://infer.techlitnow.com/v1
# CESIUM_API_KEY=   # falls back to OPENAI_API_KEY
# CESIUM_DEFAULT_MODEL=glm-5.2
# CESIUM_PROVIDER_ID=techlit
# CESIUM_MODELS=glm-5.2,kimi-k2.7-code

# --- Storage backend (OSP-75) ---
# Choose "legacy-json" (default, zero external deps) or "pg" (Postgres + Redis).
# Launch the backing services locally with `docker compose up -d` from the repo
# root, then run `npm run db:migrate --prefix server` before switching to "pg".
# OPENCURSOR_STORAGE_DRIVER=legacy-json
# DATABASE_URL=postgres://cesium:cesium@localhost:5433/cesium
# REDIS_URL=redis://localhost:6380
