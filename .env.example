# --- Next.js (browser) ---
NEXT_PUBLIC_SERVER_URL=http://localhost:9100

# --- OpenCursor server (Node) ---
# Loaded from repo root `.env.local` / `.env` when you run `npm run dev` in `server/`,
# or from `server/.env` if you prefer to keep secrets only under server/.
#
# Default workspace opened on first bootstrap. Must lie under an allowed root
# (see WORKSPACE_ALLOWED_ROOTS). If unset, the server uses the repo parent of `server/`.
WORKSPACE_ROOT=C:\Users\benpr\OneDrive\Documents\Projects\opencursor

# Optional: comma-separated absolute directory paths workspace roots may live under.
# When set, ONLY these paths are allowed (no automatic repo-root fallback).
# WORKSPACE_ALLOWED_ROOTS=C:\Users\benpr\OneDrive\Documents\Projects

# Optional escape hatch (avoid in production):
# OPENCURSOR_ALLOW_ANY_WORKSPACE_ROOT=1

# Optional CLI overrides for additional agent backends:
# OPENCURSOR_CURSOR_CLI_BIN=/absolute/path/to/agent
# OPENCURSOR_CURSOR_ACP_BIN=/absolute/path/to/agent
# Optional argv after the binary (JSON array of strings), e.g. subcommands your build needs:
# OPENCURSOR_CURSOR_AGENT_ARGS=[]
# Shorthand for Cursor agent: pass-through to --permission-mode (see Cursor CLI docs for valid values):
# OPENCURSOR_CURSOR_PERMISSION_MODE=default
# OPENCURSOR_CODEX_BIN=/absolute/path/to/codex
# OPENCURSOR_CLAUDE_BIN=/absolute/path/to/claude
#
# Optional JSON merged into ACP `initialize.clientCapabilities` (Cursor / OpenCode ACP).
# Example if the CLI rejects tools until terminal delegation is advertised:
# OPENCURSOR_ACP_CLIENT_CAPABILITIES_JSON={"terminal":true}

# Optional speech-to-text provider for composer voice input.
# Uses the OpenAI Node SDK against an OpenAI-compatible transcription endpoint.
# Defaults:
# - If only GROQ_API_KEY is set, OpenCursor assumes https://api.groq.com/openai/v1
#   with whisper-large-v3-turbo.
# - Otherwise it defaults to https://api.openai.com/v1 with gpt-4o-mini-transcribe.
# OPENCURSOR_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# OPENCURSOR_TRANSCRIPTION_API_KEY=<secret>
# OPENCURSOR_TRANSCRIPTION_MODEL=<transcription-model-id>
# OPENCURSOR_TRANSCRIPTION_LANGUAGE=en
# OPENCURSOR_TRANSCRIPTION_PROMPT=
# OPENCURSOR_TRANSCRIPTION_RESPONSE_FORMAT=text
# OPENCURSOR_TRANSCRIPTION_TIMEOUT_MS=60000
# OPENCURSOR_TRANSCRIPTION_ORGANIZATION=
# OPENCURSOR_TRANSCRIPTION_PROJECT=
